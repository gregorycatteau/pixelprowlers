# PIXELPROWLERS, Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values for your environment.
# In production, NEVER commit .env, use a secrets manager or CI/CD env vars.
#
# DATABASE_URL is mandatory when DJANGO_DEBUG=False. Individual variables are
# a development fallback only.
# ============================================================================

# ============================================================================
# DJANGO CORE
# ============================================================================

# Set to False in production. Controls debug mode, static file serving, etc.
DJANGO_DEBUG=True

# Generate a strong secret key for production. Never reuse or commit it.
# In dev, it falls back to an insecure dev key if empty.
# Generate one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Comma-separated list of allowed hostnames. Must include your domain in prod.
# Dev example: 127.0.0.1,localhost,pixelprowlers-django
# Prod example: pixelprowlers.io,www.pixelprowlers.io
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# ============================================================================
# DATABASE, Option A: DATABASE_URL (takes precedence)
# ============================================================================
# Format: postgresql://user:password@host:port/dbname
# The values below are placeholders, not working credentials.

DATABASE_URL=postgresql://app_user:replace_me@postgres:5432/pixelprowlers

# ============================================================================
# DATABASE, Option B: Individual Variables (fallback if DATABASE_URL empty)
# ============================================================================

POSTGRES_DB=pixelprowlers
POSTGRES_USER=pixelprowlers
POSTGRES_PASSWORD=replace_me
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# Legacy aliases (also supported, lower priority than POSTGRES_*)
# DB_NAME=pixelprowlers
# DB_USER=pixelprowlers
# DB_PASSWORD=pixelprowlers_dev
# DB_HOST=127.0.0.1
# DB_PORT=5433

# ============================================================================
# CORS & CSRF (Frontend Origin Security)
# ============================================================================
# Comma-separated list of origins allowed to make requests to this API.
# Dev: http://localhost:3000,http://localhost:5173
# Prod: https://pixelprowlers.io,https://www.pixelprowlers.io

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://pixelprowlers.io,https://www.pixelprowlers.io

# Whether to allow credentials (cookies, auth headers) in CORS requests.
# Usually False unless your frontend explicitly needs it.
CORS_ALLOW_CREDENTIALS=False

# Trusted origins for CSRF token validation (must be https in production).
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173,https://pixelprowlers.io,https://www.pixelprowlers.io

# ============================================================================
# SSL/SECURITY (Production Only)
# ============================================================================
# These are auto-enabled when DJANGO_DEBUG=False. Override if needed:

# Redirect all HTTP requests to HTTPS (production only).
# DJANGO_SECURE_SSL_REDIRECT=True

# Mark session cookies as secure (HTTPS only).
# DJANGO_SESSION_COOKIE_SECURE=True

# Mark CSRF cookies as secure (HTTPS only).
# DJANGO_CSRF_COOKIE_SECURE=True

# HSTS settings (tell browsers to always use HTTPS for this domain).
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# DJANGO_SECURE_HSTS_PRELOAD=True

# Tell Django that the request came through an HTTPS reverse proxy.
# Set this if you're behind Nginx/HAProxy that handles SSL termination.
# DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO

# Allow X-Forwarded-Host header (set by reverse proxy).
DJANGO_USE_X_FORWARDED_HOST=True

# ============================================================================
# EMAIL (SMTP Configuration)
# ============================================================================
# Use the console backend only in development.

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=5

# Must be an address explicitly authorized in Brevo on pixelprowlers.io.
DEFAULT_FROM_EMAIL=
SERVER_EMAIL=

# Internal email addresses for alerts and notifications.
CONTACT_NOTIFICATION_RECIPIENT=contact@example.invalid
CONTACT_HMAC_SECRET=
AUDIT_INTERNAL_EMAIL=
URGENCY_INTERNAL_EMAIL=

# ============================================================================
# SMS (Twilio Integration)
# ============================================================================

# Set to False to actually send SMS in production.
SMS_DRY_RUN=True

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
INTERNAL_SMS_TO=

# ============================================================================
# WEBHOOKS & INTEGRATIONS
# ============================================================================

# Webhook URL for urgency notifications.
WEBHOOK_URL=
WEBHOOK_TOKEN=

# HMAC signing key for audit response signatures.
AUDIT_SIGNATURE_KEY=

# Only list the direct proxy peer addresses that are actually deployed.
# Keep empty when Django is directly reachable in development.
TRUSTED_PROXY_IPS=
DJANGO_MAX_REQUEST_BODY_BYTES=1048576

# ============================================================================
# LOCALIZATION
# ============================================================================
# Already set in settings.py (fr-fr, Europe/Paris), but can be overridden here.

# LANGUAGE_CODE=fr-fr
# TIME_ZONE=Europe/Paris

# ============================================================================
# FRONTEND (Nuxt Environment)
# ============================================================================
# These are typically set in frontend .env, but can also be passed to containers.

NODE_ENV=production
NITRO_HOST=0.0.0.0
NITRO_PORT=3000

# GraphQL API endpoint (as seen by frontend).
NUXT_PUBLIC_GRAPHQL_API_URL=/graphql/

# ============================================================================
# END
# ============================================================================
